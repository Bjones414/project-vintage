# =============================================================================
# playwright-worker — Environment Variables
# Copy to .env and fill in real values for local development.
# Set these in Railway environment variables for production.
# =============================================================================

# Shared secret that authenticates requests from the Vercel app.
# Must match PLAYWRIGHT_WORKER_SECRET in the Vercel project environment.
# Generate with: openssl rand -hex 32
PLAYWRIGHT_WORKER_SECRET=replace-with-64-char-hex-secret

# Port the Express server listens on.
# Railway sets PORT automatically; local dev defaults to 3000 if unset.
PORT=3000

# Set to "false" for local development to see the browser window.
# Always "true" in production (Railway).
PLAYWRIGHT_HEADLESS=false
