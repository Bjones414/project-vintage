# =============================================================================
# Project Vintage — Environment Variables
# Copy this file to .env.local and fill in real values for local development.
# Staging and production values are managed in Vercel environment variables.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------

# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key (safe to expose to the browser — RLS enforces access control)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (server-side only — bypasses RLS; treat as a secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# Used for transactional email (welcome, alerts, weekly digest)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------

# Secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
# Used to verify the Stripe-Signature header on incoming webhook events
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# -----------------------------------------------------------------------------
# PostHog — https://app.posthog.com/project/settings
# Used for product analytics
# -----------------------------------------------------------------------------

# Project API key (safe to expose to the browser)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key

# PostHog host (use https://app.posthog.com for PostHog Cloud, or your self-hosted URL)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Sentry — https://sentry.io → Project Settings → SDK Setup
# Used for error tracking in scrapers and background jobs
# -----------------------------------------------------------------------------

# DSN for server-side Sentry reporting (keep secret — contains project ID)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# DSN for client-side Sentry reporting (same value, safe to expose to the browser)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Sentry auth token — used by @sentry/nextjs to upload source maps at build time
# Generate at: https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Sentry org and project slugs (used by the Sentry webpack plugin during builds)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

# Canonical site URL — used for absolute URL generation (OG images, email links, etc.)
# No trailing slash. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cron job security
# -----------------------------------------------------------------------------

# Secret token that POST /api/cron/scrape validates via the Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex-string
